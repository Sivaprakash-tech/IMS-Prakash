# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# Postgres (transactional + Timescale)
POSTGRES_USER=ims
POSTGRES_PASSWORD=ims_pw
POSTGRES_DB=ims
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MongoDB (raw signals)
MONGO_USER=ims
MONGO_PASSWORD=ims_pw
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=ims_signals

# Redis (cache + dedup)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Ingestion
QUEUE_MAXSIZE=50000
QUEUE_BACKPRESSURE_THRESHOLD=0.80
DEDUP_WINDOW_SECONDS=10
WORKER_COUNT=8
RATE_LIMIT_PER_SECOND=1000
THROUGHPUT_LOG_INTERVAL=5

# Dashboard
BACKEND_URL=http://backend:8000
DASHBOARD_REFRESH_SECONDS=2
